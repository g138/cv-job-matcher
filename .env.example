# ── Required ──────────────────────────────────────────────────────────────────
# Groq API key — free at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Serper API key — required for job searching on LinkedIn, Indeed & web
# Free at https://serper.dev (2,500 free searches/month)
SERPER_API_KEY=your-serper-api-key-here

# ── Web server (optional overrides) ───────────────────────────────────────────
PORT=8000

# ── For non-interactive / scheduled CLI runs ──────────────────────────────────
# CANDIDATE_NAME=Jane Doe
# CV_FILE_PATH=/path/to/cv.pdf
# JOB_LOCATION=London, UK
